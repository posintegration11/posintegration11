# PostgreSQL (local Docker, or any Postgres host)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_pos?schema=public"

# --- Supabase ---
# Official: direct db.* host is IPv6-first; many Windows/ISP networks cannot use it → use Session pooler (IPv4).
# Dashboard → Connect → Connection pooling → Session mode → copy URI (do not invent the hostname).
# Session user is postgres.<project-ref> (with a dot), not plain postgres.
#
# Your project ref: aynkrhojqbdvmfijekte  →  user: postgres.aynkrhojqbdvmfijekte
# Example shape (replace YOUR_PASSWORD and REGION from the Connect panel, e.g. ap-south-1):
# DATABASE_URL="postgresql://postgres.aynkrhojqbdvmfijekte:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=public&sslmode=require&connect_timeout=30"
#
# Do NOT use Transaction pooler (port 6543 / pgbouncer=true) for this API — Prisma interactive
# $transaction() needs one persistent connection; transaction mode causes:
# "Transaction not found... old closed transaction". Always use Session pooler :5432 above.
#
# Optional paid fix: Settings → Add-ons → IPv4 for direct db.* connection.
# After DATABASE_URL works:  npm run db:push  (schema may already exist if you used Supabase SQL/MCP)

# API (apps/api)
PORT=4000
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"

# Multi-tenant / email (apps/api)
# Base URL of the web app (verification links). No trailing slash.
APP_PUBLIC_URL="http://localhost:3000"
# Comma-separated emails that may call GET/PATCH /api/v1/platform/* as SUPER_ADMIN
PLATFORM_ADMIN_EMAILS="platform@pos.local"
# Optional transactional email — without SMTP_HOST, verification links are NOT emailed (only server logs).
#
# --- Resend (https://resend.com) ---
# 1) API Keys → create key (re_...). Use as SMTP_PASS below.
# 2) No domain yet? Use Resend’s test sender (good for dev / first tests):
#    SMTP_FROM="onboarding@resend.dev"
#    See: https://resend.com/docs/send-with-smtp (example uses onboarding@resend.dev)
#    For real customers / production, verify your own domain and switch to e.g. noreply@yourdomain.com
# 3) With a domain: Resend → Domains → verify DNS → then SMTP_FROM=noreply@yourdomain.com
# 4) APP_PUBLIC_URL = your live POS web URL (https, no trailing slash).
#
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_PASTE_YOUR_RESEND_API_KEY_HERE
SMTP_FROM="onboarding@resend.dev"
#
# On Render: add these under the API service → Environment. Redeploy after saving.
# Testing without inbox (private only): EXPOSE_VERIFY_LINK_WITHOUT_SMTP=true
# Seed: platform admin user email override
# PLATFORM_ADMIN_EMAIL="platform@pos.local"

# Web (apps/web) — browser calls API (from the *browser*, not the Next server).
# Use http://localhost:4000 only when the site is also opened on this PC.
# Phone / another PC: use this machine's LAN IP and set CORS_ORIGIN to the web origin (e.g. http://192.168.1.5:3000).
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"

# --- Android installable app (Capacitor shell, sideload APK — not Play Store) ---
# 1) apps/android-shell/.env from .env.example → CAPACITOR_SERVER_URL=https://your-frontend-host (no trailing slash)
# 2) npm run install:android && npm run android:sync
# 3) Android Studio: open apps/android-shell/android → Build APK (Debug) → install on phone
# Emulator + local Next: CAPACITOR_SERVER_URL=http://10.0.2.2:3000

# --- Render.com (replace with your real *.onrender.com names) ---
# Web: e.g. https://pos-web-boky.onrender.com  |  API: https://pos-api-tc7c.onrender.com
#
# API service (pos-api) → Environment:
#   CORS_ORIGIN=https://pos-web-boky.onrender.com
#   (no trailing slash; comma-separate if you add more front-end origins)
#   APP_PUBLIC_URL=https://pos-web-boky.onrender.com
#
# Web service (pos-web) → Environment (must exist BEFORE "npm run build"):
#   NEXT_PUBLIC_API_URL=https://pos-api-tc7c.onrender.com
#   NEXT_PUBLIC_SOCKET_URL=https://pos-api-tc7c.onrender.com
#   (no path, no trailing slash)
#
# If the site still says "Cannot reach API" after setting vars: open Web service → Manual Deploy →
# "Clear build cache & deploy". NEXT_PUBLIC_* is inlined at build time; changing env alone does not update the bundle.
# First request after idle: Render Free API may spin up slowly — retry once or hit https://pos-api-tc7c.onrender.com/health in browser.

# --- Production deploy (checklist) ---
# • Build web with NEXT_PUBLIC_API_URL and NEXT_PUBLIC_SOCKET_URL = your public API base (https://api.example.com), no trailing slash.
# • API: JWT_SECRET = long random string; never commit real secrets.
# • CORS_ORIGIN = comma-separated web origins the browser uses (e.g. https://pos.example.com,https://www.pos.example.com).
# • Database: run prisma migrate deploy OR db push against prod DATABASE_URL; verify restaurant_settings.logo_url exists.
# • HTTPS: required for PWA install and safe cookies; reverse proxy (nginx/Caddy) → API + web.
# • Smoke-test: login, table → order → KOT (if used) → billing → print, reports date range, settings save with logo (body limit 2mb on API).
