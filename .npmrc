; --- Windows (EPERM on @next/swc *.node) ---
; npm renames native binaries; Defender often locks them. Add an exclusion for this folder:
;   Windows Security → Virus & threat protection → Manage settings → Exclusions → Folder → F:\POS
; Before npm install: stop "npm run dev", close terminals using node.exe here.
; Avoid putting the repo on OneDrive/Desktop sync paths.
;
; Per-app installs under apps/* (no npm workspaces) avoid symlink EISDIR issues.
; install-links=false helps Windows when npm would otherwise symlink local packages.
install-links=false
fund=false
audit=false
