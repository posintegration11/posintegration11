{
  "name": "pos-monorepo-root",
  "private": true,
  "scripts": {
    "install:api": "cd apps/api && npm install --no-audit --no-fund",
    "install:web": "cd apps/web && npm install --no-audit --no-fund",
    "install:all": "npm install --no-audit --no-fund && npm run install:api && npm run install:web && npm run db:generate",
    "install:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-windows.ps1",
    "db:generate": "node ./node_modules/prisma/build/index.js generate",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "db:push": "node ./node_modules/prisma/build/index.js db push",
    "db:seed": "node ./node_modules/tsx/dist/cli.mjs prisma/seed.ts",
    "dev:api": "npm run dev --prefix apps/api",
    "dev:web": "npm run dev --prefix apps/web",
    "dev": "npm exec --no -- concurrently -n api,web -c blue,green npm:dev:api npm:dev:web",
    "build": "npm run build --prefix apps/api && npm run build --prefix apps/web"
  },
  "prisma": {
    "seed": "node ./node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.1.2",
    "prisma": "6.19.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
